%% barrel_inference_mcp exposes the barrel runtime as MCP tools. It is a
%% pure HTTP client over hackney against a running daemon (resolved from
%% BARREL_URL, default http://localhost:8080) and builds its tool set on
%% barrel_mcp. No Erlang dependency on the server app.

{deps, [
    {hackney, "4.0.0"},
    {barrel_mcp, "2.0.2"}
]}.

{elvis, [
    #{
        dirs => ["src"],
        filter => "*.erl",
        ruleset => erl_files_strict,
        rules => [
            {elvis_style, max_module_length, #{ignore => [barrel_inference_mcp_tools]}}
        ]
    }
]}.
