%% barrel_inference_cluster: cache-aware cluster routing facade.
%%
%% Built only under the umbrella's `cluster` profile. The sibling runtime
%% dep is resolved locally as a project app during umbrella builds and
%% shadows the same-named Hex constraint. mycelium is added alongside the
%% _state work; see the root rebar.config `cluster` profile.
{deps, [
    {barrel_inference, "0.8.0"},
    %% barrel_inference_cluster_cli is a thin HTTP client (started on demand).
    {hackney, "4.0.0"}
]}.
