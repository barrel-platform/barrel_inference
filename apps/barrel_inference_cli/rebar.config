%% barrel_inference_cli builds the `barrel-inference` escript. Shared
%% build config lives in the umbrella root rebar.config (the escript_*
%% keys and the release overlay that ships the binary). The CLI is a
%% pure HTTP client over hackney against a running daemon; `serve` execs
%% the release's barrel_inference_server start script. hackney is its
%% only dependency; it needs no Erlang dependency on the server app.

{deps, [
    {hackney, "4.0.0"}
]}.

{elvis, [
    #{
        dirs => ["src"],
        filter => "*.erl",
        ruleset => erl_files_strict,
        rules => [
            {elvis_style, no_debug_call, #{ignore => [barrel_inference_cli]}},
            {elvis_style, max_function_length, #{ignore => [barrel_inference_cli]}},
            {elvis_style, max_module_length, #{ignore => [barrel_inference_cli]}},
            {elvis_style, dont_repeat_yourself, #{ignore => [barrel_inference_cli]}}
        ]
    }
]}.
