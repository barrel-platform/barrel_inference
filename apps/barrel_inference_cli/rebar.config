%% barrel_inference_cli builds the `barrel-inference` escript. Shared
%% build config lives in the umbrella root rebar.config (the escript_*
%% keys and the release overlay that ships the binary). This app is an
%% HTTP client over hackney against a running daemon, plus `serve` which
%% boots barrel_inference_server in-process.
%%
%% hackney is listed directly because the CLI calls it directly; it also
%% arrives transitively via barrel_inference_server. barrel_inference_server
%% is a sibling umbrella app, resolved locally during umbrella builds and
%% shadowing the Hex constraint (which the published package declares).

{deps, [
    {barrel_inference_server, "0.1.0"},
    {hackney, "4.0.0"}
]}.

{elvis, [
    #{
        dirs => ["src"],
        filter => "*.erl",
        ruleset => erl_files_strict,
        rules => [
            {elvis_style, no_debug_call, #{ignore => [barrel_inference_cli]}},
            {elvis_style, max_function_length, #{ignore => [barrel_inference_cli]}},
            {elvis_style, max_module_length, #{ignore => [barrel_inference_cli]}},
            {elvis_style, dont_repeat_yourself, #{ignore => [barrel_inference_cli]}}
        ]
    }
]}.
