%% barrel_inference runtime (library). Shared build config (plugins, profiles,
%% dialyzer, xref, erlfmt) lives in the umbrella root rebar.config.
%% This file keeps only what is app-specific: the NIF build hooks and
%% the Hex/ex_doc publishing metadata. The library ships no release.

{deps, []}.

{pre_hooks, [
    {clean, "rm -f priv/*.so"},
    {clean, "rm -rf _build/cmake"},
    {"(linux|darwin|solaris)", compile, "./do_cmake.sh $BARREL_INFERENCE_OPTS"},
    {"(freebsd|netbsd|openbsd)", compile, "./do_cmake.sh $BARREL_INFERENCE_OPTS"}
]}.

{post_hooks, [
    {"(linux|darwin|solaris)", compile, "./do_llama.sh $BARREL_INFERENCE_BUILDOPTS"},
    {"(freebsd|netbsd|openbsd)", compile, "./do_llama.sh $BARREL_INFERENCE_BUILDOPTS"}
]}.

{hex, [
    {doc, ex_doc}
]}.

{ex_doc, [
    {source_url, <<"https://github.com/barrel-platform/barrel_inference">>},
    {extras, [
        {<<"README.md">>, #{title => <<"Overview">>}},
        {<<"CHANGELOG.md">>, #{title => <<"Changelog">>}},
        {<<"guides/loading.md">>, #{title => <<"Loading a model">>}},
        {<<"guides/caching.md">>, #{title => <<"Caching">>}},
        {<<"guides/configuration.md">>, #{title => <<"Configuration">>}},
        {<<"guides/building.md">>, #{title => <<"Building">>}},
        {<<"guides/examples.md">>, #{title => <<"Examples">>}},
        {<<"guides/tool-calls.md">>, #{title => <<"Tool calls">>}},
        {<<"internals/cache-design.md">>, #{title => <<"Cache design">>}},
        {<<"internals/publish-protocol.md">>, #{title => <<"Publish protocol">>}},
        {<<"internals/request-lifecycle.md">>, #{title => <<"Request lifecycle">>}},
        {<<"internals/nif-safety.md">>, #{title => <<"NIF safety">>}},
        {<<"internals/c-safety-audit.md">>, #{title => <<"C safety audit">>}},
        {<<"internals/weight-residency-bench.md">>, #{title => <<"Weight residency bench">>}},
        {<<"AGENTS.md">>, #{title => <<"Contributor guide">>}},
        {<<"UPDATE_LLAMA.md">>, #{title => <<"Updating llama.cpp">>}},
        {<<"LICENSE">>, #{title => <<"License">>}}
    ]},
    {groups_for_extras, [
        {<<"Guides">>, [
            <<"guides/loading.md">>,
            <<"guides/caching.md">>,
            <<"guides/configuration.md">>,
            <<"guides/building.md">>,
            <<"guides/examples.md">>,
            <<"guides/tool-calls.md">>
        ]},
        {<<"Internals">>, [
            <<"internals/cache-design.md">>,
            <<"internals/publish-protocol.md">>,
            <<"internals/request-lifecycle.md">>,
            <<"internals/nif-safety.md">>,
            <<"internals/c-safety-audit.md">>,
            <<"internals/weight-residency-bench.md">>
        ]},
        {<<"Contributing">>, [
            <<"AGENTS.md">>,
            <<"UPDATE_LLAMA.md">>
        ]}
    ]},
    {main, <<"readme">>}
]}.
