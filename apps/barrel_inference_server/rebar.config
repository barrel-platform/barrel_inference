%% barrel_inference_server (API daemon). Shared build config (plugins, profiles,
%% release, escript, dialyzer, xref, erlfmt) lives in the umbrella root
%% rebar.config. This file keeps the app's own Hex deps, its Elvis
%% ruleset, and its Hex/ex_doc publishing metadata.

{deps, [
    %% Cowboy 2.13's hex tarball ships a rebar.config with a hex-style
    %% version constraint that rebar3 mis-parses. Pull cowboy from
    %% git to bypass that file.
    {cowboy, {git, "https://github.com/ninenines/cowboy.git", {tag, "2.13.0"}}},
    {instrument, "1.0.0"},
    {hackney, "4.0.0"},
    %% Sibling umbrella app (apps/barrel_inference). rebar3 resolves it
    %% locally as a project app during umbrella builds, shadowing this
    %% Hex constraint; the constraint is what the published
    %% barrel_inference_server package declares.
    {barrel_inference, "0.8.0"},
    %% MCP client library (used for the server-side MCP tool bridge).
    {barrel_mcp, {git, "https://github.com/barrel-platform/barrel_mcp.git", {tag, "v2.0.1"}}}
]}.

{ct_opts, [{verbose, true}]}.

%% ex_doc configuration for the API reference rendered at
%% https://hexdocs.pm/barrel_inference_server when the package is published.
{ex_doc, [
    {source_url, <<"https://github.com/barrel-platform/barrel_inference">>},
    {homepage_url, <<"https://barrel-platform.github.io/barrel_inference/">>},
    {main, <<"readme">>},
    {extras, [
        {<<"README.md">>, #{title => <<"Overview">>}},
        {<<"CHANGELOG.md">>, #{title => <<"Changelog">>}},
        {<<"guides/quickstart.md">>, #{title => <<"Quickstart">>}},
        {<<"guides/api.md">>, #{title => <<"HTTP API">>}},
        {<<"guides/clients.md">>, #{title => <<"Clients">>}},
        {<<"guides/sizing.md">>, #{title => <<"Sizing">>}},
        {<<"guides/registry.md">>, #{title => <<"Registry">>}},
        {<<"guides/fetching.md">>, #{title => <<"Fetching">>}},
        {<<"LICENSE">>, #{title => <<"License">>}}
    ]},
    {groups_for_extras, #{
        <<"Guides">> => [
            <<"guides/quickstart.md">>,
            <<"guides/api.md">>,
            <<"guides/clients.md">>,
            <<"guides/sizing.md">>,
            <<"guides/registry.md">>,
            <<"guides/fetching.md">>
        ]
    }}
]}.

%% Hex package metadata.
{hex, [
    {doc, #{provider => ex_doc}}
]}.

{elvis, [
    #{
        dirs => ["src"],
        filter => "*.erl",
        rules => [
            {elvis_style, no_macros, disable},
            {elvis_style, no_common_caveats_call, disable},
            %% barrel_inference_server_translate is the intentional central
            %% schema translation hub; it grows by design as new
            %% endpoint shapes land.
            {elvis_style, god_modules, #{
                ignore => [barrel_inference_server_translate, barrel_inference_server_config]
            }},
            {elvis_style, no_init_lists, disable},
            {elvis_style, param_pattern_matching, disable},
            %% Modules whose state is intentionally minimal (own one
            %% ETS table) or carries a non-record map shape. Same
            %% pattern as barrel_inference_cache_ram in the barrel_inference codebase.
            {elvis_style, state_record_and_type, #{
                ignore => [
                    barrel_inference_server_config,
                    barrel_inference_server_loader,
                    barrel_inference_server_queue,
                    barrel_inference_server_registry,
                    barrel_inference_server_fetch_srv,
                    barrel_inference_server_fetch_worker,
                    barrel_inference_server_tool_replay,
                    barrel_inference_server_session_state,
                    barrel_inference_server_response_store,
                    barrel_inference_server_mcp
                ]
            }},
            {elvis_style, no_spec_with_records, #{
                ignore => [
                    barrel_inference_server_translate,
                    barrel_inference_server_pipeline,
                    barrel_inference_server_grammar,
                    barrel_inference_server_session
                ]
            }},
            {elvis_style, no_throw, #{
                ignore => [barrel_inference_server_translate, barrel_inference_server_grammar]
            }},
            {elvis_style, no_catch_expressions, #{
                ignore => [
                    barrel_inference_server_metrics,
                    barrel_inference_server_h_models,
                    barrel_inference_server_h_health,
                    barrel_inference_server_listener_mon,
                    barrel_inference_server_app,
                    barrel_inference_server_access_log,
                    barrel_inference_server_fetch_srv,
                    barrel_inference_server_fetch_worker
                ]
            }},
            {elvis_style, no_if_expression, #{
                ignore => [barrel_inference_server_queue]
            }},
            %% The handlers' info/3 dispatches and the metrics
            %% facade's init/0 are naturally long lists of clauses /
            %% setup calls. Same reasoning as barrel_inference_cache_meta_srv
            %% in the barrel_inference codebase.
            {elvis_style, max_function_length, #{
                ignore => [
                    barrel_inference_server_h_chat,
                    barrel_inference_server_h_messages,
                    barrel_inference_server_h_responses,
                    barrel_inference_server_h_ollama,
                    barrel_inference_server_metrics,
                    barrel_inference_server_sup,
                    barrel_inference_server_translate,
                    barrel_inference_server_queue,
                    barrel_inference_server_loader,
                    barrel_inference_server_config,
                    barrel_inference_server_listener_mon,
                    barrel_inference_server_fetch_worker,
                    barrel_inference_server_fetch_srv,
                    barrel_inference_server_fetch_resolvers,
                    barrel_inference_server_gguf
                ]
            }},
            {elvis_style, max_function_clause_length, #{
                ignore => [
                    barrel_inference_server_sup,
                    barrel_inference_server_metrics,
                    barrel_inference_server_queue,
                    barrel_inference_server_loader,
                    barrel_inference_server_config,
                    barrel_inference_server_h_chat,
                    barrel_inference_server_h_messages,
                    barrel_inference_server_h_responses,
                    barrel_inference_server_listener_mon,
                    barrel_inference_server_fetch_worker,
                    barrel_inference_server_translate
                ]
            }},
            {elvis_style, dont_repeat_yourself, #{
                ignore => [
                    barrel_inference_server_h_chat,
                    barrel_inference_server_h_messages,
                    barrel_inference_server_h_responses,
                    barrel_inference_server_h_api,
                    barrel_inference_server_translate
                ]
            }},
            %% gbnf() type is internal and not used in any -spec.
            %% Suppress the export-used-types rule for grammar.
            {elvis_style, export_used_types, #{
                ignore => [barrel_inference_server_grammar, barrel_inference_server_tool_executor]
            }},
            {elvis_style, max_module_length, #{
                ignore => [
                    barrel_inference_server_translate,
                    barrel_inference_server_h_chat,
                    barrel_inference_server_h_messages,
                    barrel_inference_server_h_responses,
                    barrel_inference_server_fetch_worker,
                    barrel_inference_server_fetch_srv,
                    barrel_inference_server_fetch_resolvers
                ]
            }}
        ],
        ruleset => erl_files_strict
    },
    #{
        dirs => ["."],
        filter => "rebar.config",
        rules => [
            {elvis_project, no_branch_deps, disable}
        ],
        ruleset => rebar_config
    }
]}.
