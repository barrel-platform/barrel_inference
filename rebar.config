%% Umbrella project: barrel_inference.
%%
%% Apps under apps/ are auto-discovered as project apps:
%%   apps/barrel_inference         OTP-native inference runtime (library + NIF)
%%   apps/barrel_inference_server  OpenAI/Anthropic/Ollama HTTP daemon
%% A future apps/barrel_inference_cluster drops in here with no change to
%% this file beyond adding it to the release app list below (or giving
%% it its own release).
%%
%% Each app's own rebar.config owns its Hex dependencies so the apps
%% publish to Hex independently. A sibling dep (server -> runtime) is
%% resolved locally as a project app during umbrella builds and shadows
%% the same-named Hex constraint.

{minimum_otp_vsn, "28"}.

{erl_opts, [debug_info, warnings_as_errors]}.

{deps, []}.

{project_plugins, [
    {rebar3_proper, "~> 0.12.1"},
    {rebar3_hex, "~> 7.1.0"},
    {rebar3_ex_doc, "~> 0.3.0"},
    {rebar3_lint, "~> 5.0.4"},
    {erlfmt, "~> 1.8.0"}
]}.

{shell, [
    {config, "config/sys.config"},
    {apps, [barrel_inference_server]}
]}.

%% One product release: the API daemon. The runtime is a library and
%% ships no release of its own. The CLI escript (apps/barrel_inference_cli,
%% main module barrel_inference_cli) is built by escriptize and dropped
%% into the release bin/ via the overlay below.
{relx, [
    {release, {barrel_inference_server, "0.8.0"}, [
        sasl,
        os_mon,
        barrel_inference_server,
        barrel_inference,
        instrument,
        livery,
        barrel_mcp
    ]},
    {sys_config, "config/sys.config"},
    {vm_args, "config/vm.args"},
    {dev_mode, true},
    {include_erts, false},
    {include_src, false},
    {extended_start_script, true},
    {overlay, [
        {mkdir, "log"},
        {copy, "{{base_dir}}/bin/barrel-inference", "bin/barrel-inference"}
    ]}
]}.

%% Build the escript before relx assembles the release so the overlay
%% source path exists on a fresh tree.
{provider_hooks, [
    {pre, [{release, escriptize}]}
]}.

{escript_main_app, barrel_inference_cli}.
{escript_name, "barrel-inference"}.
{escript_emu_args, "%%! -escript main barrel_inference_cli\n"}.

{profiles, [
    {prod, [
        {relx, [
            {mode, prod},
            {dev_mode, false},
            {include_erts, true},
            {include_src, false}
        ]}
    ]},
    {test, [
        {erl_opts, [debug_info, nowarn_export_all]},
        {deps, [{proper, "~> 1.4.0"}]}
    ]}
]}.

%% Single umbrella PLT across all apps and their deps. CI keys the PLT
%% cache on the root rebar.lock hash. Strict warning set; the unmatched
%% returns (cache/model modules) and the unknown pool_policy/0 type are
%% fixed in the source rather than suppressed.
{dialyzer, [
    {warnings, [error_handling, no_return, unmatched_returns, unknown]},
    {plt_apps, all_deps},
    {plt_extra_apps, [os_mon, inets, ssl]}
]}.

{xref_checks, [
    undefined_function_calls,
    locals_not_used,
    deprecated_function_calls
]}.

{erlfmt, [
    write,
    {files, [
        "apps/*/{src,test,include}/**/*.{hrl,erl,app.src,escript}",
        "apps/*/rebar.config",
        "rebar.config"
    ]}
]}.
