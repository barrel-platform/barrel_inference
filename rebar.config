%% Umbrella project: barrel_inference.
%%
%% Apps under apps/ are auto-discovered as project apps:
%%   apps/barrel_inference         OTP-native inference runtime (library + NIF)
%%   apps/barrel_inference_server  OpenAI/Anthropic/Ollama HTTP daemon
%% A future apps/barrel_inference_cluster drops in here with no change to
%% this file beyond adding it to the release app list below (or giving
%% it its own release).
%%
%% Each app's own rebar.config owns its Hex dependencies so the apps
%% publish to Hex independently. A sibling dep (server -> runtime) is
%% resolved locally as a project app during umbrella builds and shadows
%% the same-named Hex constraint.

{minimum_otp_vsn, "28"}.

{erl_opts, [debug_info, warnings_as_errors]}.

%% quic is pinned umbrella-wide so hackney (HTTP/3, was quic 1.0.0) and the
%% cluster's mycelium overlay (needs quic >= 1.4.x, e.g. quic_dist_auth) resolve
%% the same NIF. Without this, hackney's transitive quic 1.0.0 wins the shared
%% lock and mycelium fails to compile.
{deps, [
    {quic, "1.4.3"}
]}.

%% The cluster facade (apps/barrel_inference_cluster) and its overlay
%% transport (mycelium + quic NIF) are profile-only: listed explicitly so
%% the default build never compiles them and the stock release never bundles
%% them. The `cluster` profile below adds the app back.
{project_app_dirs, [
    "apps/barrel_inference",
    "apps/barrel_inference_server",
    "apps/barrel_inference_cli"
]}.

{project_plugins, [
    {rebar3_proper, "~> 0.12"},
    {rebar3_hex, "~> 7.0"},
    {rebar3_ex_doc, "~> 0.2"},
    %% Runtime used ~> 5.0, server pinned 4.1.1. Unified to ~> 5.0;
    %% the server's elvis ruleset needs a shakeout against the newer
    %% elvis_core (rule names may have changed).
    {rebar3_lint, "~> 5.0"},
    {erlfmt, "~> 1.7"}
]}.

{shell, [
    {config, "config/sys.config"},
    {apps, [barrel_inference_server]}
]}.

%% One product release: the API daemon. The runtime is a library and
%% ships no release of its own. The CLI escript (apps/barrel_inference_cli,
%% main module barrel_inference_cli) is built by escriptize and dropped
%% into the release bin/ via the overlay below.
{relx, [
    {release, {barrel_inference_server, "0.8.0"}, [
        sasl,
        os_mon,
        barrel_inference_server,
        barrel_inference,
        cowboy,
        instrument,
        hackney,
        barrel_mcp
    ]},
    {sys_config, "config/sys.config"},
    {vm_args, "config/vm.args"},
    {dev_mode, true},
    {include_erts, false},
    {include_src, false},
    {extended_start_script, true},
    {overlay, [
        {mkdir, "log"},
        {copy, "{{base_dir}}/bin/barrel-inference", "bin/barrel-inference"}
    ]}
]}.

%% Build the escript before relx assembles the release so the overlay
%% source path exists on a fresh tree.
{provider_hooks, [
    {pre, [{release, escriptize}]}
]}.

{escript_main_app, barrel_inference_cli}.
{escript_name, "barrel-inference"}.
{escript_emu_args, "%%! -escript main barrel_inference_cli\n"}.

{profiles, [
    {prod, [
        {relx, [
            {mode, prod},
            {dev_mode, false},
            {include_erts, true},
            {include_src, false}
        ]}
    ]},
    {test, [
        {erl_opts, [debug_info, nowarn_export_all]},
        {deps, [{proper, "1.4.0"}]}
    ]},
    %% Clustered build: compiles the cluster facade and (later) pulls the
    %% mycelium overlay transport. The mycelium dep, the cluster relx release
    %% (with its own sys.config/vm.args), and the instrument reconciliation
    %% land with the _state work.
    {cluster, [
        %% Adds the cluster facade to the build (project_app_dirs merges with the
        %% default list, so the runtime/server/cli come along). No version
        %% conflict: quic is pinned to 1.4.3 at the top level (see {deps,...}
        %% above) so hackney and mycelium share one NIF, and the locked
        %% instrument 1.0.0 already exports every instrument_meter function
        %% mycelium calls (get_meter/create_counter/create_histogram/add/record).
        {project_app_dirs, ["apps/barrel_inference_cluster"]},
        {deps, [
            {mycelium,
                {git, "https://github.com/benoitc/mycelium.git",
                    {ref, "75cc6608f907ca35f18a69a63671412f980f42d5"}}}
        ]},
        %% Pull the overlay deps into the PLT so dialyzer can resolve the
        %% mycelium/quic calls the facade makes (the base config's `unknown`
        %% warning is on).
        %% Profile config replaces (not merges) plt_extra_apps, so repeat the
        %% base apps (os_mon/inets/ssl) alongside the overlay deps.
        {dialyzer, [{plt_extra_apps, [os_mon, inets, ssl, mycelium, quic, hlc]}]},
        {relx, [
            {release, {barrel_inference_cluster, "0.8.0"}, [
                sasl,
                %% os_mon: the runtime's pressure scheduler uses memsup.
                os_mon,
                barrel_inference,
                barrel_inference_cluster
            ]},
            {sys_config, "config/sys.config.cluster"},
            {vm_args, "config/vm.args.cluster"},
            {dev_mode, true},
            {include_erts, false}
        ]}
    ]}
]}.

%% Single umbrella PLT across all apps and their deps. CI keys the PLT
%% cache on the root rebar.lock hash. Strict warning set; the unmatched
%% returns (cache/model modules) and the unknown pool_policy/0 type are
%% fixed in the source rather than suppressed.
{dialyzer, [
    {warnings, [error_handling, no_return, unmatched_returns, unknown]},
    {plt_apps, all_deps},
    {plt_extra_apps, [os_mon, inets, ssl]}
]}.

{xref_checks, [
    undefined_function_calls,
    locals_not_used,
    deprecated_function_calls
]}.

{erlfmt, [
    write,
    {files, [
        "apps/*/{src,test,include}/**/*.{hrl,erl,app.src,escript}",
        "apps/*/rebar.config",
        "rebar.config"
    ]}
]}.
