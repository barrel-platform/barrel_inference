%% Umbrella-wide Elvis config (elvis_core 5.x). One root config lints every
%% app's src; the global rule disables come from the runtime's original
%% elvis.config and the per-module ignore lists merge the runtime, server,
%% and CLI exceptions. Per-app elvis settings remain for standalone
%% `cd apps/<app> && rebar3 lint`.
[
    {config, [
        #{
            files => ["apps/*/src/**/*.erl"],
            ruleset => erl_files_strict,
            rules => [
                {elvis_style, no_macros, disable},
                {elvis_style, atom_naming_convention, #{
                    regex => "^[a-z](_?[a-zA-Z0-9]+)*(_SUITE)?$"
                }},
                %% Relaxed for this codebase / new in elvis_core 5.x.
                {elvis_style, prefer_strict_generators, disable},
                {elvis_style, prefer_sigils, disable},
                {elvis_style, consistent_ok_error_spec, disable},
                {elvis_style, abc_size, disable},
                {elvis_style, code_complexity, disable},
                {elvis_style, consistent_variable_naming, disable},
                {elvis_style, prefer_robot_butt, disable},
                {elvis_style, no_common_caveats_call, disable},
                {elvis_style, no_init_lists, disable},
                {elvis_style, no_spec_with_records, disable},
                {elvis_style, param_pattern_matching, disable},
                {elvis_style, no_used_ignored_variables, disable},
                {elvis_text_style, max_line_length, #{limit => 120}},
                {elvis_style, no_invalid_dynamic_calls, #{
                    ignore => [barrel_inference_model, barrel_inference_cli]
                }},
                {elvis_style, no_throw, #{
                    ignore => [
                        barrel_inference_cache_kvc,
                        barrel_inference_server_translate,
                        barrel_inference_server_grammar,
                        barrel_inference_server_tool_format_llama_pythonic
                    ]
                }},
                {elvis_style, no_if_expression, #{
                    ignore => [barrel_inference_server_queue]
                }},
                {elvis_style, no_catch_expressions, #{
                    ignore => [
                        barrel_inference_server_metrics,
                        barrel_inference_server_h_models,
                        barrel_inference_server_h_health,
                        barrel_inference_server_listener_mon,
                        barrel_inference_server_app,
                        barrel_inference_server_access_log,
                        barrel_inference_server_fetch_srv,
                        barrel_inference_server_fetch_worker
                    ]
                }},
                {elvis_style, no_debug_call, #{
                    ignore => [barrel_inference_cli]
                }},
                %% relay_daemon/1 blocks until the launched release daemon's
                %% port reports exit_status; the loop is bounded by that, not
                %% a timeout.
                {elvis_style, no_receive_without_timeout, #{
                    ignore => [barrel_inference_cli]
                }},
                {elvis_style, export_used_types, #{
                    ignore => [
                        barrel_inference_server_grammar,
                        barrel_inference_server_tool_executor
                    ]
                }},
                {elvis_style, state_record_and_type, #{
                    ignore => [
                        barrel_inference_cache_ram,
                        barrel_inference_inflight,
                        barrel_inference_registry,
                        barrel_inference_model,
                        barrel_inference_server_config,
                        barrel_inference_server_loader,
                        barrel_inference_server_queue,
                        barrel_inference_server_registry,
                        barrel_inference_server_fetch_srv,
                        barrel_inference_server_fetch_worker,
                        barrel_inference_server_tool_replay,
                        barrel_inference_server_session_state,
                        barrel_inference_server_response_store,
                        barrel_inference_server_mcp
                    ]
                }},
                {elvis_style, max_record_fields, #{
                    ignore => [
                        barrel_inference_model,
                        barrel_inference_server_h_chat,
                        barrel_inference_server_h_chat_livery,
                        barrel_inference_server_h_responses,
                        barrel_inference_server_h_responses_livery,
                        barrel_inference_server_h_messages
                    ]
                }},
                {elvis_style, max_function_length, #{
                    ignore => [
                        barrel_inference_cache_kvc,
                        barrel_inference_cache_meta_srv,
                        barrel_inference_cache_key,
                        barrel_inference_model,
                        barrel_inference_server_h_chat,
                        barrel_inference_server_h_chat_livery,
                        barrel_inference_server_h_messages,
                        barrel_inference_server_h_responses,
                        barrel_inference_server_h_responses_livery,
                        barrel_inference_server_h_ollama,
                        barrel_inference_server_metrics,
                        barrel_inference_server_sup,
                        barrel_inference_server_translate,
                        barrel_inference_server_queue,
                        barrel_inference_server_loader,
                        barrel_inference_server_config,
                        barrel_inference_server_listener_mon,
                        barrel_inference_server_fetch_worker,
                        barrel_inference_server_fetch_srv,
                        barrel_inference_server_fetch_resolvers,
                        barrel_inference_server_gguf,
                        barrel_inference_cli
                    ]
                }},
                {elvis_style, max_function_clause_length, #{
                    ignore => [
                        barrel_inference_cache_kvc,
                        barrel_inference_model,
                        barrel_inference_server_sup,
                        barrel_inference_server_metrics,
                        barrel_inference_server_queue,
                        barrel_inference_server_loader,
                        barrel_inference_server_config,
                        barrel_inference_server_h_chat,
                        barrel_inference_server_h_messages,
                        barrel_inference_server_h_responses,
                        barrel_inference_server_listener_mon,
                        barrel_inference_server_fetch_worker,
                        barrel_inference_server_translate
                    ]
                }},
                {elvis_style, max_module_length, #{
                    ignore => [
                        barrel_inference_cache_meta_srv,
                        barrel_inference_model,
                        barrel_inference_server_translate,
                        barrel_inference_server_pipeline,
                        barrel_inference_server_h_chat,
                        barrel_inference_server_h_chat_livery,
                        barrel_inference_server_h_messages,
                        barrel_inference_server_h_responses,
                        barrel_inference_server_h_responses_livery,
                        barrel_inference_server_fetch_worker,
                        barrel_inference_server_fetch_srv,
                        barrel_inference_server_fetch_resolvers,
                        barrel_inference_cli
                    ]
                }},
                {elvis_style, dont_repeat_yourself, #{
                    ignore => [
                        barrel_inference_model,
                        barrel_inference_server_models,
                        barrel_inference_server_h_chat,
                        barrel_inference_server_h_chat_livery,
                        barrel_inference_server_h_messages,
                        barrel_inference_server_h_responses,
                        barrel_inference_server_h_responses_livery,
                        barrel_inference_server_h_api,
                        barrel_inference_server_translate,
                        barrel_inference_cli
                    ]
                }},
                {elvis_style, no_god_modules, #{
                    ignore => [
                        barrel_inference,
                        barrel_inference_nif,
                        barrel_inference_model,
                        barrel_inference_model_llama,
                        barrel_inference_model_stub,
                        barrel_inference_server_translate,
                        barrel_inference_server_config
                    ]
                }}
            ]
        },
        #{
            files => ["apps/*/include/**/*.hrl"],
            ruleset => hrl_files,
            rules => [{elvis_style, no_types, disable}]
        },
        #{
            files => ["apps/*/rebar.config", "rebar.config"],
            ruleset => rebar_config
        }
    ]}
].
